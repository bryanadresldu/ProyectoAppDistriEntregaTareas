[mysqld]
# Identificador unico obligatorio para replicacion (debe ser distinto al de la replica)
server-id = 1

# Fuerza que MySQL trabaje siempre en UTC, sin importar la zona horaria
# del sistema operativo del host/contenedor. Esto es lo que garantiza que
# NOW() y las fechas limite de las tareas sean consistentes con lo que el
# backend (timezone: 'Z' en mysql2) y el frontend (interpretacion "Z")
# asumen en todo el proyecto.
default-time-zone = '+00:00'

# Habilita el binary log: registro de todas las escrituras que la replica
# usara para reproducir los cambios del Master.
log-bin = mysql-bin
binlog_format = ROW

# Base de datos que se replicara (limita el trafico de binlog a lo relevante)
binlog_do_db = tareas_db

# Buenas practicas de rendimiento/consistencia para el binlog
sync_binlog = 1
expire_logs_days = 7

# GTID: simplifica y hace mas confiable la configuracion de replicacion
gtid_mode = ON
enforce_gtid_consistency = ON

bind-address = 0.0.0.0
