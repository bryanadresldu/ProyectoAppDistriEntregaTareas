[mysqld]
# Identificador unico obligatorio para replicacion (distinto al del Master)
server-id = 2

# Mismo motivo que en el Master: mantener todo el sistema en UTC de forma explicita.
default-time-zone = '+00:00'

# Relay log: donde la replica almacena temporalmente los eventos
# recibidos del binlog del Master antes de aplicarlos.
relay-log = mysql-relay-bin
log-bin = mysql-bin
binlog_format = ROW

# La replica es de solo lectura: toda escritura normal debe ir al Master.
# NOTA: solo "read_only" (sin "super_read_only"). Con super_read_only=ON
# ni siquiera el propio proceso de arranque de MySQL (que usa privilegios
# de root/SUPER para inicializar el usuario root y ejecutar
# init-replica.sh) puede escribir, y la inicializacion falla con el
# error "MySQL server is running with the --super-read-only option".
# read_only=ON ya es suficiente para impedir escrituras de la app y de
# cualquier usuario normal; el hilo de replicacion no se ve afectado.
read_only = ON

gtid_mode = ON
enforce_gtid_consistency = ON

bind-address = 0.0.0.0
