# =============================================================
# Copia este archivo como ".env" antes de levantar el proyecto.
# Docker Compose lo carga automaticamente.
# =============================================================

# ---- Base de datos ----
MYSQL_ROOT_PASSWORD=RootPass123!
MYSQL_DATABASE=tareas_db
DB_USER=root
DB_PASSWORD=RootPass123!
DB_NAME=tareas_db

# ---- Seguridad ----
# Cambia este valor por una cadena larga y aleatoria en un entorno real.
JWT_SECRET=una_clave_secreta_academica_super_larga_2026
JWT_EXPIRES_IN=2h

# ---- Puerto publico de NGINX ----
HTTP_PORT=80

# ---- Puertos publicos de MySQL (expuestos hacia el host/Windows) ----
# Permiten conectarse con clientes externos como MySQL Workbench,
# DBeaver, HeidiSQL, etc. desde fuera de Docker.
MYSQL_MASTER_PORT=3306
MYSQL_REPLICA_PORT=3307

# ---- Puerto publico de phpMyAdmin ----
PHPMYADMIN_PORT=8081
